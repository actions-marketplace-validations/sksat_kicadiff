{
  "name": "kicadiff",
  "version": "0.1.0",
  "description": "Visual diff tool for KiCad PCB and schematic files",
  "type": "module",
  "bin": {
    "kicadiff": "./kicadiff"
  },
  "scripts": {
    "test": "playwright test",
    "typecheck": "tsc --noEmit",
    "build:bun": "bun build --compile src/index.ts --outfile dist/kicadiff",
    "build:bun:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/kicadiff-linux-x64",
    "build:bun:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/kicadiff-linux-arm64",
    "build:bun:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/kicadiff-darwin-arm64",
    "build:bun:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile dist/kicadiff-darwin-x64",
    "build:bun:all": "pnpm run build:bun:linux-x64 && pnpm run build:bun:linux-arm64 && pnpm run build:bun:darwin-arm64 && pnpm run build:bun:darwin-x64"
  },
  "keywords": [
    "kicad",
    "diff",
    "pcb",
    "schematic",
    "visual-diff"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@types/which": "^3.0.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "which": "^7.0.0"
  }
}
