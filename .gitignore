node_modules/
test/fixtures/
test-results/
dist/
src/viewer-content.ts

# API keys / secrets for gemini-cli (don't commit alongside settings.json).
.gemini/.env

# Claude Code runtime artifacts under .claude/ (scheduled task locks etc.)
.claude/scheduled_tasks.lock

# kicadiff renders by default into <repo>/.claude/preview/.
.claude/preview/

# kicad-mcp-pro stages generated footprints / exports under output/
# next to the active project's .kicad_pro.
examples/*/output/

# KiCad runtime artifacts (per-user state, lock files, autosave/backup
# directories — all regenerated as KiCad opens / works on the project).
*.kicad_prl
*.lck
~*.lck
*-backups/
.history/
~_autosave-*
